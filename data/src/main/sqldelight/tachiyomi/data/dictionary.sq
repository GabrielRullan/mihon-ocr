CREATE TABLE dictionary (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    simplified TEXT NOT NULL,
    traditional TEXT NOT NULL,
    pinyin TEXT NOT NULL,
    english TEXT NOT NULL
);

CREATE INDEX dictionary_simplified_index ON dictionary(simplified);
CREATE INDEX dictionary_traditional_index ON dictionary(traditional);

getEntryBySimplified:
SELECT * FROM dictionary WHERE simplified = ?;

getEntryBySimplifiedOrTraditional:
SELECT * FROM dictionary WHERE simplified = ? OR traditional = ?;

getEntriesBySimplifiedList:
SELECT * FROM dictionary WHERE simplified IN ?;

insert:
INSERT INTO dictionary (simplified, traditional, pinyin, english)
VALUES (?, ?, ?, ?);

deleteAll:
DELETE FROM dictionary;

count:
SELECT COUNT(*) FROM dictionary;
